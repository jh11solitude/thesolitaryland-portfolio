# ─────────────────────────────────────────────
# PYTHON
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/

# ─────────────────────────────────────────────
# VIRTUAL ENVIRONMENT
# ─────────────────────────────────────────────
venv/
env/
ENV/
.venv/

# ─────────────────────────────────────────────
# DJANGO
# ─────────────────────────────────────────────

# NEVER commit your secret key or database password
.env
.env.*

# Uploaded user media — these are runtime files, not source code
media/

# Collected static files — generated by collectstatic, not source
staticfiles/

# Django migrations ARE committed (they're source code)
# Do NOT add migrations/ to .gitignore

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
*.sqlite3
*.db

# ─────────────────────────────────────────────
# EDITORS & OS
# ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml

# ─────────────────────────────────────────────
# LOGS & TEMP FILES
# ─────────────────────────────────────────────
*.log
*.pot
*.pyc
.cache
pip-log.txt
pip-delete-this-directory.txt